# Supabase — leave blank to run in local/demo mode (data stored in browser).
# With these set, the app requires sign-in and syncs all data to Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CoinSpot live balance sync (server-only — never exposed to the browser).
# Generate a READ-ONLY API key: CoinSpot → Profile → API.
COINSPOT_API_KEY=
COINSPOT_API_SECRET=
